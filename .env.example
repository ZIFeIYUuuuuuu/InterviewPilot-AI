# InterviewPilot AI local environment template.
# Copy this file to .env and fill secrets locally. Do not commit .env.

INTERVIEWPILOT_ENV=local
INTERVIEWPILOT_HOST=127.0.0.1
INTERVIEWPILOT_PORT=8000
INTERVIEWPILOT_RELOAD=false
INTERVIEWPILOT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional LLM provider. Leave API key empty to use the local deterministic MVP engine.
INTERVIEWPILOT_LLM_ENABLED=true
INTERVIEWPILOT_LLM_API_KEY=
INTERVIEWPILOT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTERVIEWPILOT_LLM_MODEL=glm-5
INTERVIEWPILOT_LLM_TIMEOUT_SECONDS=30

# Optional local persistence path.
INTERVIEWPILOT_STORE_PATH=data/interviewpilot_store.json
